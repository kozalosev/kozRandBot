TOKEN=123456789:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=2048
DEFAULT_PASSWORD_LENGTH=12
# Additional non-alphanumeric characters used in generated passwords
PASSWORD_EXTRA_CHARS=
MAX_PASSWORD_GENERATION_TRIES=100
# Comma-separated list of Telegram user IDs with premium (SystemRandom) access
PREMIUM_USERS_UID=

NAME=kozRandBot
APP_HOST=0.0.0.0
APP_PORT=8080
# Required when DEBUG=false (webhook mode)
HOST=bots.example.org
SERVER_PORT=8443
METRICS_PORT=8000
UNIX_SOCKET=/tmp/kozRandBot.sock
SOCKET_TYPE=TCP

# e.g. socks5://127.0.0.1:2080
PROXY=

# Set to 'false' for production use. Determines polling vs webhooks.
DEBUG=true
